# /etc/infrastructure/bootstrap/.env
#
# Copy to /etc/infrastructure/bootstrap/.env on each node, chmod 0600.
# This file is host-local and must NEVER be committed to the public repo.
#
# Re-run run.sh whenever this file changes.
#
# Architecture this template targets:
#   M720q  =  k3s SERVER + dnsmasq + MinIO + your DBs (postgres, mongo, redis)
#   Pi     =  k3s AGENT only (worker node, no stateful services)
# Flip the role/toggle blocks below depending on which host you're configuring.

# ─── Repo location (only override if you fork the repo) ──────────────────────
# REPO_RAW_URL=https://raw.githubusercontent.com/markmorcos/infrastructure/main/bootstrap

# ─── Component toggles ────────────────────────────────────────────────────────
INSTALL_SYSCTL_FORWARD=1
INSTALL_TAILSCALE=1
INSTALL_K3S=1
INSTALL_CF_DDNS=1
INSTALL_K3S_CLEANUP=1
INSTALL_MINIO=1            # M720q: 1   |   Pi (agent): 0
INSTALL_POSTGRES=1         # M720q: 1   |   Pi (agent): 0
INSTALL_MONGO=1            # M720q: 1   |   Pi (agent): 0
INSTALL_REDIS=1            # M720q: 1   |   Pi (agent): 0
INSTALL_DNSMASQ=1          # M720q: 1   |   Pi (agent): 0

# ─── Tailscale ────────────────────────────────────────────────────────────────
# Generate auth key at https://login.tailscale.com/admin/settings/keys
# (reusable=false, ephemeral=false, tags=optional)
TAILSCALE_AUTHKEY=tskey-auth-...
TAILSCALE_HOSTNAME=                # leave empty = use `hostname`
TAILSCALE_ADVERTISE_EXIT_NODE=1    # both nodes can advertise; pick one in app
TAILSCALE_AUTO_UPDATE=1            # keeps tailscale on the latest stable version
TAILSCALE_ACCEPT_DNS=1             # MUST be 1 — required for split-DNS to morcos.lan
TAILSCALE_SSH=1                    # Tailscale handles SSH auth via tailnet identity;
                                   # no SSH keys, no passwords, no authorized_keys file.
                                   # Manage access in admin → Access Controls.

# ─── k3s ──────────────────────────────────────────────────────────────────────
# M720q (server):
#   K3S_ROLE=server
#   K3S_URL=             (unused)
#   K3S_TOKEN=           (k3s generates one; grab it from
#                         /var/lib/rancher/k3s/server/node-token after install
#                         to put in Pi's env below)
# Pi (agent):
#   K3S_ROLE=agent
#   K3S_URL=https://<m720q-tailscale-ip>:6443
#   K3S_TOKEN=K10b...::server:...           # from M720q
K3S_ROLE=server
K3S_URL=
K3S_TOKEN=
K3S_VERSION=v1.32.3+k3s1
K3S_DISABLE=traefik

# ─── Cloudflare DDNS — anchor record pattern (both nodes run it; idempotent) ──
# ONE A record tracks your public IP. All app domains are CNAMEs to it (set
# those up once in Cloudflare; DDNS never touches them again).
#
# Create token at https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone → DNS → Edit; include zones containing the anchor record
CF_API_TOKEN=your-cf-token
CF_ANCHOR_RECORD=morcos.tech        # the one A record DDNS updates (apex or subdomain both work)
CF_ANCHOR_PROXIED=true              # apex is usually proxied; safe either way for DDNS
CF_DDNS_INTERVAL=5min               # systemd time: 5min, 1h, 30s

# ─── MinIO (only used when INSTALL_MINIO=1) ───────────────────────────────────
MINIO_ROOT_USER=minio-user
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_VOLUMES=/mnt/data/minio
MINIO_OPTS=--address 0.0.0.0:9000 --console-address 0.0.0.0:9001
MINIO_BROWSER_REDIRECT_URL=https://minio.morcos.tech
MINIO_SERVER_URL=https://cdn.morcos.tech
# MINIO_VERSION=RELEASE.2025-01-01T00-00-00Z   # leave empty for latest

# ─── PostgreSQL (only used when INSTALL_POSTGRES=1) ───────────────────────────
# Native install from the PGDG repo. Data lives on the data volume and the
# server binds on all interfaces (gated by Tailscale/firewall). Reach it at
# postgres.morcos.lan (see the dnsmasq catalog).
POSTGRES_VERSION=16                  # major version (PGDG)
POSTGRES_PASSWORD=change-me-strong-password   # the `postgres` superuser password
POSTGRES_USER=postgres              # optional extra login role (leave as postgres to skip)
POSTGRES_DB=                        # optional db created and owned by POSTGRES_USER
POSTGRES_DATA=/mnt/data/postgres
POSTGRES_PORT=5432
POSTGRES_LISTEN=*                   # listen_addresses; '*' = all interfaces
# POSTGRES_REPO_DIST=noble          # pin apt codename if PGDG lacks your release

# ─── MongoDB (only used when INSTALL_MONGO=1) ─────────────────────────────────
# Native install from the official mongodb-org repo (amd64/arm64 only — keep on
# the M720q). Auth enabled; binds on all interfaces. Reach it at mongo.morcos.lan.
# Mongo only ships repos for LTS releases (Ubuntu focal/jammy/noble, Debian
# bullseye/bookworm); on a newer release it auto-falls back to the nearest one.
# NOTE: MongoDB 8.x won't start on Linux kernel >=6.19 (SERVER-121912). On such
# a host, pin MONGO_VERSION=7.0 (unaffected) until you're on a <6.19 kernel.
MONGO_VERSION=8.0                    # release series (mongodb-org); use 7.0 on kernel >=6.19
MONGO_ROOT_USER=mongo-admin
MONGO_ROOT_PASSWORD=change-me-strong-password
MONGO_DATA=/mnt/data/mongo
MONGO_PORT=27017
MONGO_BIND_IP=0.0.0.0
# MONGO_REPO_DIST=noble             # force the apt codename (overrides auto-fallback)

# ─── Redis (only used when INSTALL_REDIS=1) ───────────────────────────────────
# Native install from the official packages.redis.io repo. Password-protected,
# AOF persistence on the data volume, binds on all interfaces. redis.morcos.lan.
REDIS_PASSWORD=change-me-strong-password
REDIS_DATA=/mnt/data/redis
REDIS_PORT=6379
REDIS_BIND=0.0.0.0
# REDIS_REPO_DIST=noble             # pin apt codename if redis.io lacks your release

# ─── dnsmasq (only used when INSTALL_DNSMASQ=1) ───────────────────────────────
# After bootstrap on M720q:
#   1. Edit /etc/infrastructure/dnsmasq/morcos.lan.hosts to set the IPs you want
#      each service name to resolve to (default: M720q's own tailscale IP)
#   2. Reload:  sudo systemctl reload dnsmasq
#   3. In Tailscale admin → DNS → Nameservers → Add Custom:
#        Nameserver IP          = M720q's tailscale IP
#        Restrict to domain     = morcos.lan
#        (Optionally) add morcos.lan to Search Domains for bare-name resolution
DNSMASQ_DOMAIN=morcos.lan
