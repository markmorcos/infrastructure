{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "required": ["version", "project", "services"],
  "definitions": {
    "probe": {
      "type": "object",
      "description": "Kubernetes probe (startup/liveness/readiness)",
      "properties": {
        "httpGet": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "port": { "type": ["integer", "string"] },
            "scheme": { "type": "string", "enum": ["HTTP", "HTTPS"] },
            "host": { "type": "string" },
            "httpHeaders": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "value"],
                "properties": {
                  "name": { "type": "string" },
                  "value": { "type": "string" }
                }
              }
            }
          }
        },
        "tcpSocket": {
          "type": "object",
          "properties": {
            "port": { "type": ["integer", "string"] },
            "host": { "type": "string" }
          }
        },
        "exec": {
          "type": "object",
          "properties": {
            "command": { "type": "array", "items": { "type": "string" } }
          }
        },
        "grpc": {
          "type": "object",
          "properties": {
            "port": { "type": "integer" },
            "service": { "type": "string" }
          }
        },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "properties": {
    "version": {
      "type": "string",
      "description": "Version of the Helm chart"
    },
    "project": {
      "type": "string",
      "description": "Name of the project"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "image"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Service and deployment name"
          },
          "image": {
            "type": "string",
            "description": "Container image to use"
          },
          "serviceAccountName": {
            "type": "string",
            "description": "Pod ServiceAccount name. Set when the service needs Kubernetes API access (e.g. reading/writing secrets). The ServiceAccount + RBAC must be provisioned separately (see k8s/)."
          },
          "tag": {
            "type": "string",
            "default": "latest",
            "description": "Image tag (default 'latest')"
          },
          "pullPolicy": {
            "type": "string",
            "enum": ["Always", "IfNotPresent", "Never"],
            "default": "Always",
            "description": "Image pull policy"
          },
          "ports": {
            "type": "array",
            "description": "List of ports to expose",
            "items": {
              "type": "object",
              "required": ["port"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Name of the port",
                  "default": "http"
                },
                "protocol": {
                  "type": "string",
                  "enum": ["TCP", "UDP"],
                  "default": "TCP",
                  "description": "Protocol for the port"
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535,
                  "description": "Container port to expose"
                },
                "targetPort": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535,
                  "description": "Target port on the container",
                  "default": "<port>"
                }
              }
            }
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535,
            "description": "Port exposed by the service"
          },
          "replicas": {
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Number of deployment replicas"
          },
          "terminationGracePeriodSeconds": {
            "type": "integer",
            "minimum": 0,
            "description": "Grace period before SIGKILL during pod termination"
          },
          "resources": {
            "type": "object",
            "description": "Container resource requests and limits",
            "properties": {
              "requests": {
                "type": "object",
                "properties": {
                  "cpu": { "type": ["string", "number"] },
                  "memory": { "type": "string" }
                }
              },
              "limits": {
                "type": "object",
                "properties": {
                  "cpu": { "type": ["string", "number"] },
                  "memory": { "type": "string" }
                }
              }
            }
          },
          "startupProbe": { "$ref": "#/definitions/probe" },
          "livenessProbe": { "$ref": "#/definitions/probe" },
          "readinessProbe": { "$ref": "#/definitions/probe" },
          "context": {
            "type": "string",
            "description": "Optional override for the Docker build context"
          },
          "env": {
            "type": "array",
            "description": "Environment variables",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Environment variable name"
                },
                "value": {
                  "type": "string",
                  "description": "Literal environment variable value"
                },
                "valueFrom": {
                  "type": "object",
                  "description": "Value from config/secret",
                  "properties": {
                    "secretKeyRef": {
                      "type": "object",
                      "required": ["name", "key"],
                      "properties": {
                        "name": { "type": "string" },
                        "key": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "ingress": {
            "type": "object",
            "required": ["path", "pathType"],
            "anyOf": [{ "required": ["host"] }, { "required": ["hosts"] }],
            "properties": {
              "host": { "type": "string", "description": "Ingress hostname (single host)" },
              "hosts": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1,
                "description": "Multiple ingress hostnames served by this service (e.g. a wildcard plus its apex). Use instead of `host`; all are added to the TLS SANs and rules."
              },
              "www": {
                "type": "boolean",
                "default": false,
                "description": "Add a www.<host> TLS SAN and enable the from-to-www redirect. Only enable when a www DNS record exists for the host, otherwise the HTTP-01 challenge for www.<host> will fail."
              },
              "tlsSecret": {
                "type": "string",
                "description": "Override the TLS secret name. Defaults to <namespace>-<service>-tls so each ingress gets its own certificate. Set this to a shared value only when several services intentionally serve the same host/cert."
              },
              "proxyBodySize": {
                "type": "string",
                "description": "Max request body size (nginx proxy-body-size, e.g. \"8m\"). Defaults to nginx's 1m when unset. Raise for services that accept uploads; it also caps oversized bodies as a DoS guard."
              },
              "path": {
                "type": "string",
                "description": "Ingress path for this service"
              },
              "pathType": {
                "type": "string",
                "description": "Ingress path type",
                "enum": ["Exact", "Prefix", "ImplementationSpecific"]
              }
            }
          },
          "volumes": {
            "type": "array",
            "description": "Volume definitions used for mounting into the container",
            "items": {
              "type": "object",
              "required": ["name", "mountPath"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Name of the volume"
                },
                "mountPath": {
                  "type": "string",
                  "description": "Path where the volume is mounted inside the container"
                },
                "readOnly": {
                  "type": "boolean",
                  "description": "Whether the mount is read-only"
                },
                "secret": {
                  "type": "object",
                  "description": "Secret volume definition",
                  "properties": {
                    "secretName": { "type": "string" },
                    "optional": { "type": "boolean" },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["key", "path"],
                        "properties": {
                          "key": { "type": "string" },
                          "path": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "configMap": {
                  "type": "object",
                  "description": "ConfigMap volume definition",
                  "properties": {
                    "name": { "type": "string" },
                    "optional": { "type": "boolean" }
                  }
                },
                "emptyDir": {
                  "type": "object",
                  "description": "Tmpfs or emptyDir storage",
                  "properties": {
                    "medium": { "type": "string" },
                    "sizeLimit": { "type": "string" }
                  }
                },
                "hostPath": {
                  "type": "object",
                  "description": "HostPath volume definition",
                  "properties": {
                    "path": { "type": "string" },
                    "type": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
